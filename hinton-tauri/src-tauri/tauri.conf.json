{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hinton",
  "version": "0.1.0",
  "identifier": "com.sasa.hinton",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Hinton",
        "url": "loading.html",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720,
        "backgroundColor": "#0f1011"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../../python-embed": "python-embed",
      "../../harness": "harness",
      "../../frontend": "frontend",
      "../../plugins": "plugins",
      "../../bin": "bin"
    }
  }
}
